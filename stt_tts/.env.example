# Azure TTS
AZURE_TTS_KEY=your-azure-tts-key-here
AZURE_TTS_ENDPOINT=https://francecentral.tts.speech.microsoft.com/cognitiveservices/v1
AZURE_TTS_VOICE=en-US-AriaNeural

# HubSpot
HUBSPOT_API_KEY=your-hubspot-api-key-here

# PostgreSQL
DATABASE_USER=postgres
DATABASE_PASSWORD=your-db-password
DATABASE_HOST=localhost
DATABASE_PORT=5432

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0

# JWT
JWT_SECRET_KEY=changeme-use-a-real-secret-in-production

# Service URLs
USER_SERVICE_URL=http://localhost:8006
SESSION_SERVICE_URL=http://localhost:8005
MESSAGE_SERVICE_URL=http://localhost:8003
